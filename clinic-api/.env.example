# ============================================================
# clinic-api environment — copy to .env and fill real values
# cp .env.example .env
# ============================================================

# Database (PostgreSQL) — REQUIRED. App throws on startup if missing.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://clinic_user:CHANGE_ME@localhost:5433/clinic_db"

# Redis (optional, for queues/cache)
REDIS_URL="redis://localhost:6379"

# JWT — use long random strings in production
JWT_SECRET="CHANGE_ME_long_random_secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_ME_long_random_refresh_secret"
JWT_REFRESH_EXPIRES_IN="7d"

# MinIO / S3 file storage (optional)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="CHANGE_ME"
MINIO_SECRET_KEY="CHANGE_ME"
MINIO_BUCKET="clinic-files"

# App
PORT=3001
NODE_ENV="development"

# CORS — comma-separated allowed frontend origins
FRONTEND_URLS="http://localhost:3000,http://localhost:3002,http://localhost:3003"
